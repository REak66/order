# Server Configuration
PORT=5002
NODE_ENV=production

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lunch_order_db?appName=<appName>

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_ID=your_telegram_group_id_here
TIME_ZONE=Asia/Phnom_Penh

# Admin Configuration (Initial Admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS - Set this to your Vercel frontend URL after deploying
FRONTEND_URL=https://your-frontend.vercel.app
